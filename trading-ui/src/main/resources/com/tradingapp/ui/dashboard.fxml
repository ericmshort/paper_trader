<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<TabPane xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         fx:controller="com.tradingapp.ui.DashboardController"
         tabClosingPolicy="UNAVAILABLE"
         style="-fx-background-color: #1a1a2e;">

    <tabs>

        <!-- Live Trading tab -->
        <Tab text="Live Trading">
            <content>
                <VBox style="-fx-background-color: #1a1a2e;">

                    <!-- Section 1: Portfolio labels -->
                    <VBox style="-fx-background-color: #16213e; -fx-padding: 10;" spacing="8">
                        <!-- Row 1: Portfolio values + halt indicator -->
                        <HBox spacing="20">
                            <Label fx:id="totalPortfolioLabel"
                                   text="Total Portfolio: $100,000.00"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00ff88;"/>
                            <Label fx:id="stockHoldingsLabel"
                                   text="Stocks: $0.00"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                            <Label fx:id="optionHoldingsLabel"
                                   text="Options: $0.00"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                            <Label fx:id="availableCashLabel"
                                   text="Cash: $100,000.00"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                            <Label fx:id="optionsCashDeployedLabel"
                                   text="Options Reserved: $0.00"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                            <Label fx:id="haltedLabel"
                                   text=""
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ff4444;"/>
                        </HBox>
                        <!-- Row 2: Performance stats -->
                        <HBox spacing="20">
                            <Label fx:id="winsLabel"
                                   text="Wins: 0"
                                   style="-fx-font-size: 14px; -fx-text-fill: #00ff88;"/>
                            <Label fx:id="lossesLabel"
                                   text="Losses: 0"
                                   style="-fx-font-size: 14px; -fx-text-fill: #ff4444;"/>
                            <Label fx:id="winRateLabel"
                                   text="Win Rate: 0%"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                            <Button fx:id="pnlButton"
                                    text="P&amp;L: $0.00"
                                    onAction="#onPnlClicked"
                                    style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0; -fx-background-color: transparent; -fx-border-color: transparent; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;"/>
                            <Label fx:id="unrealizedPnlLabel"
                                   text="Unrealized P&amp;L: $0.00"
                                   style="-fx-font-size: 14px; -fx-text-fill: #e0e0e0;"/>
                        </HBox>
                    </VBox>

                    <!-- Section 2: Equity chart (full width) -->
                    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 5;" spacing="3">
                        <Label text="Equity Curve"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                        <LineChart fx:id="equityChart"
                                   VBox.vgrow="ALWAYS"
                                   animated="false"
                                   createSymbols="false"
                                   legendVisible="false"
                                   style="-fx-background-color: #1a1a2e;">
                            <xAxis>
                                <NumberAxis tickLabelsVisible="false" tickMarkVisible="false"
                                            minorTickVisible="false" forceZeroInRange="false"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Portfolio ($)" forceZeroInRange="false"/>
                            </yAxis>
                        </LineChart>
                    </VBox>

                    <!-- Section 3: Research + Trade history -->
                    <HBox VBox.vgrow="ALWAYS" spacing="5" style="-fx-padding: 5;">
                        <!-- Left: Research -->
                        <VBox HBox.hgrow="ALWAYS" spacing="3">
                            <Label text="Research"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                            <Separator/>
                            <TextArea fx:id="researchArea"
                                      editable="false"
                                      wrapText="true"
                                      VBox.vgrow="ALWAYS"
                                      style="-fx-control-inner-background: #1a1a2e; -fx-text-fill: #c0c0c0; -fx-font-size: 11px;"/>
                        </VBox>
                        <!-- Right: Trade history -->
                        <VBox HBox.hgrow="ALWAYS" spacing="3">
                            <Label text="Trade History"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                            <Separator/>
                            <TableView fx:id="tradeHistoryTable"
                                       VBox.vgrow="ALWAYS"
                                       style="-fx-background-color: #1a1a2e;">
                                <columns>
                                    <TableColumn fx:id="colTimestamp" text="Time" prefWidth="90"/>
                                    <TableColumn fx:id="colSymbol" text="Symbol" prefWidth="80"/>
                                    <TableColumn fx:id="colAction" text="Action" prefWidth="60"/>
                                    <TableColumn fx:id="colQuantity" text="Qty" prefWidth="60"/>
                                    <TableColumn fx:id="colPrice" text="Price" prefWidth="90"/>
                                    <TableColumn fx:id="colFee" text="Fee" prefWidth="60"/>
                                    <TableColumn fx:id="colBalance" text="Balance" prefWidth="110"/>
                                    <TableColumn fx:id="colReason" text="Reason" prefWidth="250"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </Tab>

        <!-- Options Positions tab -->
        <Tab text="Options Positions">
            <content>
                <VBox style="-fx-background-color: #1a1a2e; -fx-padding: 10;" spacing="5">
                    <Label text="Open Options Positions"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                    <Separator/>
                    <TableView fx:id="optionsTable"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #1a1a2e;">
                        <columns>
                            <TableColumn fx:id="optColSymbol" text="Symbol" prefWidth="80"/>
                            <TableColumn fx:id="optColType" text="Type" prefWidth="60"/>
                            <TableColumn fx:id="optColStrike" text="Strike" prefWidth="90"/>
                            <TableColumn fx:id="optColExpiry" text="Expiry" prefWidth="110"/>
                            <TableColumn fx:id="optColContracts" text="Qty" prefWidth="50"/>
                            <TableColumn fx:id="optColEntryPrem" text="Entry Prem" prefWidth="110"/>
                            <TableColumn fx:id="optColCurrentPrem" text="Curr Prem" prefWidth="110"/>
                            <TableColumn fx:id="optColUnrealizedPnl" text="Unrealized P&amp;L" prefWidth="130"/>
                        </columns>
                    </TableView>
                    <Separator/>
                    <Label fx:id="optionsTotalUnrealizedLabel"
                           text="Total Unrealized P&amp;L: $0.00"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                </VBox>
            </content>
        </Tab>

        <!-- Stock Positions tab -->
        <Tab text="Stock Positions">
            <content>
                <VBox style="-fx-background-color: #1a1a2e; -fx-padding: 10;" spacing="5">
                    <Label text="Open Stock Positions"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                    <Separator/>
                    <TableView fx:id="stockPositionsTable"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #1a1a2e;">
                        <columns>
                            <TableColumn fx:id="stkColSymbol" text="Symbol" prefWidth="80"/>
                            <TableColumn fx:id="stkColQuantity" text="Shares" prefWidth="70"/>
                            <TableColumn fx:id="stkColAvgCost" text="Avg Cost" prefWidth="100"/>
                            <TableColumn fx:id="stkColCurrentPrice" text="Current Price" prefWidth="120"/>
                            <TableColumn fx:id="stkColMarketValue" text="Market Value" prefWidth="120"/>
                            <TableColumn fx:id="stkColUnrealizedPnl" text="Unrealized P&amp;L" prefWidth="130"/>
                        </columns>
                    </TableView>
                    <Separator/>
                    <Label fx:id="stockTotalUnrealizedLabel"
                           text="Total Unrealized P&amp;L: $0.00"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
                </VBox>
            </content>
        </Tab>

        <!-- Backtest tab -->
        <Tab text="Backtest">
            <content>
                <fx:include fx:id="backtestPanel" source="backtest-panel.fxml"/>
            </content>
        </Tab>

        <!-- Settings tab -->
        <Tab text="Settings">
            <content>
                <fx:include fx:id="settingsPanel" source="settings.fxml"/>
            </content>
        </Tab>

    </tabs>

</TabPane>
