<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tradingapp.ui.SettingsController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background: #1a1a2e; -fx-background-color: #1a1a2e;">

<VBox style="-fx-background-color: #1a1a2e; -fx-padding: 20;"
      spacing="16">

    <Label text="Settings"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>
    <Separator/>

    <!-- Broker section -->
    <Label text="Broker"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Broker Type:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <ComboBox fx:id="brokerTypeCombo" prefWidth="200"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" fx:id="alpacaRow">
        <Label text="API Key:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="apiKeyField" prefWidth="340"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="PKXXXXXXXXXXXXXXXXXXXXXXXX"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" fx:id="alpacaSecretRow">
        <Label text="API Secret:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <PasswordField fx:id="apiSecretField" prefWidth="340"
                       style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                       promptText="••••••••••••••••••••••••••••••••••••••••"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" fx:id="alpacaUrlRow">
        <Label text="Base URL:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="baseUrlField" prefWidth="340"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #888888;"
                   editable="false"/>
    </HBox>

    <Separator/>

    <!-- Quote provider section -->
    <Label text="Market Data"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Quote Provider:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <ComboBox fx:id="quoteProviderCombo" prefWidth="200"/>
    </HBox>

    <Label fx:id="quoteProviderNote"
           text=""
           wrapText="true"
           style="-fx-font-size: 11px; -fx-text-fill: #888888;"
           maxWidth="520"/>

    <HBox fx:id="testWsRow" spacing="12" alignment="CENTER_LEFT">
        <Button fx:id="testWsButton" text="Test WebSocket"
                onAction="#onTestWebSocket"
                style="-fx-background-color: #16213e; -fx-text-fill: #00ff88; -fx-border-color: #00ff88; -fx-border-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <Separator/>

    <!-- AI / News Sentiment section -->
    <Label text="AI News Sentiment"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Claude API Key:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <PasswordField fx:id="claudeApiKeyField" prefWidth="340"
                       style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                       promptText="sk-ant-…"/>
    </HBox>
    <Label text="Used for pre-market news sentiment analysis. Leave blank to disable. Get a key at console.anthropic.com."
           style="-fx-font-size: 11px; -fx-text-fill: #888888;" wrapText="true" maxWidth="520"/>

    <Separator/>

    <!-- Risk settings section -->
    <Label text="Risk Controls"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Daily Loss Limit:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="dailyLossLimitField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="5.0"/>
        <Label text="(% of portfolio value, 0 = disabled)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Max Exposure:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="maxPortfolioExposureField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="60"/>
        <Label text="(% of portfolio committed to stock and options positions, 1–100)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Market Regime:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <CheckBox fx:id="marketRegimeFilterCheck"
                  style="-fx-text-fill: #e0e0e0;"
                  text="Block new stock buys when SPY is below its 5-day MA (short-term trend)"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Overnight Holds:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <CheckBox fx:id="avoidOvernightHoldsCheck"
                  style="-fx-text-fill: #e0e0e0;"
                  text="Force-close all positions at 15:45 ET (avoid overnight holds)"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Overnight Floor:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="overnightFloorField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="80"/>
        <Label text="pct of entry — when holding overnight, close EOD losers below this floor (0 = hold all)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Earnings Blackout:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="earningsBlackoutField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="3"/>
        <Label text="days before earnings (0 = disabled, stocks only)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Circuit Breaker:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="circuitBreakerField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="2.0"/>
        <Label text="% daily loss — auto-liquidate all stocks + halt trading (0 = disabled)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <Separator/>

    <!-- Stock Strategies section -->
    <Label text="Stock Strategies"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <CheckBox fx:id="stockTradingEnabledCheck" text="Enable Stock Trading"
              style="-fx-text-fill: #e0e0e0;"/>

    <Label text="Select which stock strategies can open new positions. Disabled strategies still close existing positions."
           style="-fx-font-size: 11px; -fx-text-fill: #888888;" wrapText="true" maxWidth="520"/>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <CheckBox fx:id="strategyOpeningBreakout" text="Opening Breakout" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyStochasticReversal" text="Stochastic Reversal" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyRelativeStrengthDivergence" text="RS Divergence" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyMacdCrossover" text="MACD Crossover" style="-fx-text-fill: #e0e0e0;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Trailing Stop:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="trailingStopField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="4"/>
        <Label text="% — close position when price falls this % from its peak (1–15)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Max Loss/Trade:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="maxLossPerTradeField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="0.30"/>
        <Label text="% of portfolio risked per stock trade — sizes each position (0.1–1.0)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <VBox spacing="4">
        <Label text="Stock Watchlist:" style="-fx-text-fill: #e0e0e0;"/>
        <TextArea fx:id="stockWatchlistArea" prefHeight="72" wrapText="true"
                  style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0; -fx-font-size: 11px;"
                  promptText="AAPL, MSFT, NVDA, ..."/>
        <Label text="Comma-separated list of symbols to trade stocks on. Leave blank to use all watchlist symbols."
               style="-fx-text-fill: #888888; -fx-font-size: 11px;" wrapText="true" maxWidth="520"/>
    </VBox>

    <Separator/>

    <!-- Options Strategies section -->
    <Label text="Options Strategies"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>

    <CheckBox fx:id="optionsTradingEnabledCheck" text="Enable Options Trading"
              style="-fx-text-fill: #e0e0e0;"/>

    <VBox spacing="4">
        <Label text="Options Watchlist:" style="-fx-text-fill: #e0e0e0;"/>
        <TextArea fx:id="optionsWatchlistArea" prefHeight="72" wrapText="true"
                  style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0; -fx-font-size: 11px;"
                  promptText="SPY, NVDA, MSFT, ..."/>
        <Label text="Comma-separated list of symbols eligible for options trading."
               style="-fx-text-fill: #888888; -fx-font-size: 11px;" wrapText="true" maxWidth="520"/>
    </VBox>

    <Label text="Select which options strategies can open new positions. Disabled strategies still close existing positions."
           style="-fx-font-size: 11px; -fx-text-fill: #888888;" wrapText="true" maxWidth="520"/>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <CheckBox fx:id="strategyHighDeltaScalp" text="High-Delta Scalp" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyMomentumNearTerm" text="Momentum Near-Term" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyLongCall" text="Long Call" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyLongPut" text="Long Put" style="-fx-text-fill: #e0e0e0;"/>
        <CheckBox fx:id="strategyZeroDte" text="Zero-DTE (Fridays)" style="-fx-text-fill: #e0e0e0;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Options Stop-Loss:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="optionsStopLossField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="30"/>
        <Label text="exit when premium drops to this pct of entry cost (10–90)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Profit Target:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="profitTargetField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="2.5"/>
        <Label text="× entry premium to close at profit (e.g. 2.5 = 150% gain)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Reversal Signals:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="reversalMinSignalsField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="5"/>
        <Label text="opposing signals required per tick to trigger reversal exit (1–6)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Last Entry:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="entryCutoffField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="14:45"/>
        <Label text="ET — no new positions after this time (HH:mm, leave blank for no cutoff)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Entry Confirmation:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="entryConfirmationTicksField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="12"/>
        <Label text="consecutive 5s ticks required before opening a position (1 = off, 12 = 60s)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Put Min Signals:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="downtrendPutMinSignalsField" prefWidth="60"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="3"/>
        <Label text="sell signals required to open a put during SPY downtrend (1–6)"
               style="-fx-text-fill: #888888; -fx-font-size: 11px;"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Calls Disabled:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="callsDisabledField" prefWidth="380"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="e.g. MSFT,TSLA  (leave blank for none)"/>
    </HBox>
    <Label text="Symbols in this list may trade puts but not calls."
           style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Puts Disabled:" style="-fx-text-fill: #e0e0e0;" prefWidth="140"/>
        <TextField fx:id="putsDisabledField" prefWidth="380"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"
                   promptText="e.g. NVDA  (leave blank for none)"/>
    </HBox>
    <Label text="Symbols in this list may trade calls but not puts."
           style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>

    <Separator/>

    <!-- Actions -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button fx:id="testConnectionButton" text="Test Connection"
                onAction="#onTestConnection"
                style="-fx-background-color: #16213e; -fx-text-fill: #00ff88; -fx-border-color: #00ff88; -fx-border-radius: 4; -fx-cursor: hand;"/>
        <Button text="Save Settings"
                onAction="#onSaveSettings"
                style="-fx-background-color: #00ff88; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-border-radius: 4; -fx-cursor: hand;"/>
        <Label fx:id="statusLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #00ff88;"/>
    </HBox>

    <Label text="Settings are stored in ~/.tradingapp/app.properties and are never committed to git."
           style="-fx-font-size: 11px; -fx-text-fill: #555555;"
           wrapText="true" maxWidth="520"/>

</VBox>
</ScrollPane>
